    "sass": "^1.51.0",
    "style-it": "^2.1.4",
    "stylelint": "^17.4.0",
    "stylelint-config-recommended-scss": "17.0.0",
    "stylelint-scss": "7.0.0",
    "stylelint-use-logical": "^2.1.3",
